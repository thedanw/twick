{
  "name": "@twick/studio",
  "version": "0.15.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./dist/studio.css": "./dist/studio.css",
    "./dist/themes/new-light-studio.css": "./dist/themes/new-light-studio.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "license": "https://github.com/ncounterspecialist/twick/blob/main/LICENSE.md",
  "files": [
    "dist",
    "dist/themes"
  ],
  "scripts": {
    "build": "tsc --noEmit && vite build && node -e \"require('fs').cpSync('src/themes','dist/themes',{recursive:true})\"",
    "dev": "vite build --watch",
    "lint": "eslint src/",
    "clean": "rimraf .turbo node_modules dist",
    "docs": "typedoc --options ./typedoc.json",
    "test": "echo \"No tests for @twick/studio\" && exit 0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@twick/ai-models": "workspace:*",
    "@twick/canvas": "workspace:*",
    "@twick/core": "^0.15.17",
    "@twick/workflow": "workspace:*",
    "@twick/live-player": "workspace:*",
    "@twick/media-utils": "workspace:*",
    "@twick/player-react": "^0.15.17",
    "@twick/timeline": "workspace:*",
    "@twick/video-editor": "workspace:*",
    "@twick/visualizer": "workspace:*",
    "@twick/effects": "workspace:*",
    "lucide-react": "^0.511.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@types/react": "^18.0.0 || ^19.0.0",
    "@types/react-dom": "^18.0.0 || ^19.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "@twick/timeline": "workspace:*",
    "@twick/live-player": "workspace:*",
    "@twick/video-editor": "workspace:*",
    "rimraf": "^5.0.5",
    "typedoc": "^0.25.8",
    "typedoc-plugin-markdown": "^3.17.1",
    "typescript": "^5.4.2",
    "vite": "^5.4.21",
    "vite-plugin-dts": "^3.7.3"
  }
}